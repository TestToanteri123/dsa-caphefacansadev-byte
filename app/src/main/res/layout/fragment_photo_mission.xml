<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="16dp">

    <TextView
        android:id="@+id/photoInstructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:alpha="0.9"
        android:gravity="center"
        android:text="@string/photo_instruction"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cameraPreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/black"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/photoInstructionText"
        app:layout_constraintWidth_percent="0.85">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextureView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/permissionOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:background="@color/black"
                android:contentDescription="@string/camera_permission_required"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/permissionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/camera_permission_required"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <View
        android:id="@+id/cameraFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/camera_frame_overlay"
        app:layout_constraintBottom_toBottomOf="@id/cameraPreviewCard"
        app:layout_constraintEnd_toEndOf="@id/cameraPreviewCard"
        app:layout_constraintStart_toStartOf="@id/cameraPreviewCard"
        app:layout_constraintTop_toTopOf="@id/cameraPreviewCard" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/similarityIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:indicatorColor="@color/white"
        app:trackColor="@android:color/transparent"
        app:indicatorSize="48dp"
        app:layout_constraintBottom_toBottomOf="@id/cameraPreviewCard"
        app:layout_constraintEnd_toEndOf="@id/cameraPreviewCard"
        app:layout_constraintStart_toStartOf="@id/cameraPreviewCard"
        app:layout_constraintTop_toTopOf="@id/cameraPreviewCard"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/similarityText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/similarityIndicator"
        app:layout_constraintEnd_toEndOf="@id/similarityIndicator"
        app:layout_constraintStart_toStartOf="@id/similarityIndicator"
        app:layout_constraintTop_toTopOf="@id/similarityIndicator"
        tools:text="75%"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/captureButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/capture_photo"
        android:textColor="@color/white"
        app:backgroundTint="@color/purple_500"
        app:cornerRadius="24dp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconTint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cameraPreviewCard" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/autoCaptureToggle"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/auto_capture_on"
        android:textColor="@color/white"
        app:strokeColor="@color/white"
        app:cornerRadius="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/captureButton" />

    <TextView
        android:id="@+id/statusMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:alpha="0.7"
        android:gravity="center"
        android:visibility="gone"
        tools:text="@string/matching_photo"
        tools:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/autoCaptureToggle" />

    <TextView
        android:id="@+id/setupHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:alpha="0.5"
        android:gravity="center"
        android:visibility="gone"
        android:text="@string/photo_setup_hint"
        tools:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusMessage" />

</androidx.constraintlayout.widget.ConstraintLayout>
